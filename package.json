{
  "name": "tu-tien-itsm-dashboard",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "sync": "tsx scripts/sync-data.ts",
    "seed": "tsx scripts/seed-mock.ts",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "docker:build": "docker build -t tu-tien-dashboard .",
    "docker:run": "docker run -p 3000:3000 tu-tien-dashboard",
    "analyze": "ANALYZE=true pnpm build"
  },
  "dependencies": {
    "@react-three/fiber": "^8.15.16",
    "@react-three/drei": "^9.99.0",
    "@auth/core": "^0.28.0",
    "next-auth": "^5.0.0-beta.15",
    "clsx": "^2.1.0",
    "framer-motion": "^11.0.5",
    "lucide-react": "^0.344.0",
    "next": "14.1.0",
    "next-intl": "^3.9.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "three": "^0.162.0",
    "zustand": "^4.5.1",
    "mathjs": "^12.4.0",
    "zod": "^3.22.4",
    "@tanstack/react-query": "^5.24.1",
    "@sentry/nextjs": "^7.105.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "@types/three": "^0.162.0",
    "@testing-library/react": "^14.2.1",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/user-event": "^14.5.2",
    "@vitest/coverage-v8": "^1.3.1",
    "@vitest/ui": "^1.3.1",
    "@playwright/test": "^1.42.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.1.0",
    "eslint-plugin-testing-library": "^6.2.0",
    "eslint-plugin-playwright": "^1.5.0",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1",
    "@next/bundle-analyzer": "^14.1.0"
  },
  "packageManager": "pnpm@8.15.3",
  "engines": {
    "node": ">=18.17.0"
  }
